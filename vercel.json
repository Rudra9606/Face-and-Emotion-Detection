{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": [
          "Models/**",
          "Image_Generator/**",
          "Test_Images/**",
          "Harcascade/**",
          "*.ipynb"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
